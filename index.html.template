<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Daily Tech Recap — {{DATE}}</title>
  <meta property="og:title" content="Daily Tech & AI Recap — {{DATE}}" />
  <meta property="og:description" content="{{TLDR_PREVIEW}}" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://{{USERNAME}}.github.io/daily-recap/" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Syne:wght@700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0C0C0F; --surface: #141417; --surface2: #1C1C21;
      --border: rgba(255,255,255,0.07); --border2: rgba(255,255,255,0.12);
      --text: #F0EFE8; --muted: #8A8A96;
      --accent: #6C63FF; --accent2: #00D4A4;
      --danger: #FF5C5C; --amber: #F5A623; --blue: #4A9EFF;
      --radius-sm: 6px; --radius-md: 10px; --radius-lg: 16px;
      --font-display: 'Syne', sans-serif; --font-body: 'Inter', sans-serif;
    }
    html { scroll-behavior: smooth; }
    body { background: var(--bg); color: var(--text); font-family: var(--font-body); font-size: 15px; line-height: 1.7; min-height: 100vh; }
    header { border-bottom: 1px solid var(--border); padding: 2rem 0 1.5rem; }
    .container { max-width: 780px; margin: 0 auto; padding: 0 1.5rem; }
    .header-top { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
    .logo { font-family: var(--font-display); font-size: 1.1rem; font-weight: 800; letter-spacing: -0.02em; color: var(--text); text-decoration: none; display: flex; align-items: center; gap: 8px; }
    .logo-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); display: inline-block; }
    .date-badge { font-size: 12px; color: var(--muted); background: var(--surface2); border: 1px solid var(--border); padding: 4px 12px; border-radius: 999px; }
    .headline { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 0.5rem; }
    .headline span { color: var(--accent); }
    .subline { font-size: 14px; color: var(--muted); }
    .bio-card { display: flex; align-items: center; gap: 1rem; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1rem 1.5rem; margin: 1.5rem auto; max-width: 780px; }
    .bio-avatar { width: 44px; height: 44px; border-radius: 50%; background: rgba(108,99,255,0.2); color: var(--accent); font-family: var(--font-display); font-size: 15px; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .bio-info { display: flex; flex-direction: column; gap: 3px; }
    .bio-name { font-family: var(--font-display); font-size: 15px; font-weight: 700; color: var(--text); }
    .bio-tagline { font-size: 12px; color: var(--muted); }
    .bio-links { display: flex; gap: 12px; margin-top: 4px; }
    .bio-links a { display: flex; align-items: center; gap: 4px; font-size: 12px; color: var(--accent); text-decoration: none; transition: opacity 0.15s; }
    .bio-links a:hover { opacity: 0.75; }
    .tldr-strip { background: var(--surface); border: 1px solid var(--border); border-left: 3px solid var(--accent); border-radius: var(--radius-md); padding: 1.25rem 1.5rem; margin: 2rem 0; }
    .tldr-label { font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.75rem; }
    .tldr-list { list-style: none; display: flex; flex-direction: column; gap: 6px; counter-reset: item; }
    .tldr-list li { font-size: 13.5px; color: var(--text); display: flex; align-items: baseline; gap: 8px; }
    .tldr-list li::before { content: counter(item); counter-increment: item; font-size: 11px; font-weight: 600; color: var(--accent); min-width: 16px; }
    .section { margin: 2.5rem 0; }
    .section-header { display: flex; align-items: center; gap: 10px; margin-bottom: 1.25rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--border); }
    .section-icon { width: 32px; height: 32px; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; font-size: 15px; flex-shrink: 0; }
    .section-title { font-family: var(--font-display); font-size: 1rem; font-weight: 700; letter-spacing: -0.01em; color: var(--text); }
    .section-count { margin-left: auto; font-size: 11px; color: var(--muted); background: var(--surface2); padding: 2px 8px; border-radius: 999px; }
    .theme-ai .section-icon { background: rgba(108,99,255,0.15); color: var(--accent); }
    .theme-tech .section-icon { background: rgba(74,158,255,0.15); color: var(--blue); }
    .theme-sec .section-icon { background: rgba(255,92,92,0.15); color: var(--danger); }
    .theme-oss .section-icon { background: rgba(0,212,164,0.15); color: var(--accent2); }
    .theme-dev .section-icon { background: rgba(245,166,35,0.15); color: var(--amber); }
    .story-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.25rem 1.5rem; margin-bottom: 0.75rem; transition: border-color 0.15s, background 0.15s; text-decoration: none; display: block; color: inherit; }
    .story-card:hover { border-color: var(--border2); background: var(--surface2); }
    .story-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; flex-wrap: wrap; }
    .story-source { font-size: 11px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; color: var(--muted); }
    .story-tag { font-size: 11px; padding: 2px 8px; border-radius: 999px; font-weight: 500; }
    .theme-ai .story-tag { background: rgba(108,99,255,0.15); color: var(--accent); }
    .theme-tech .story-tag { background: rgba(74,158,255,0.15); color: var(--blue); }
    .theme-sec .story-tag { background: rgba(255,92,92,0.15); color: var(--danger); }
    .theme-oss .story-tag { background: rgba(0,212,164,0.15); color: var(--accent2); }
    .theme-dev .story-tag { background: rgba(245,166,35,0.15); color: var(--amber); }
    .story-headline { font-family: var(--font-display); font-size: 1rem; font-weight: 700; letter-spacing: -0.01em; color: var(--text); margin-bottom: 6px; line-height: 1.3; }
    .story-summary { font-size: 13.5px; color: var(--muted); line-height: 1.65; }
    footer { border-top: 1px solid var(--border); padding: 2rem 0; margin-top: 3rem; text-align: center; }
    footer p { font-size: 12px; color: var(--muted); line-height: 1.8; }
    footer a { color: var(--accent); text-decoration: none; }
    @media (max-width: 600px) { .header-top { flex-direction: column; align-items: flex-start; } .bio-card { flex-direction: column; align-items: flex-start; } }
  </style>
</head>
<body>
<header>
